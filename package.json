{
  "name": "@j0hanz/gemini-assistant",
  "version": "0.1.0",
  "description": "Workflow-first MCP server for Google Gemini with sessions and workspace context",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "gemini-assistant": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j0hanz/gemini-assistant.git"
  },
  "keywords": [
    "mcp",
    "gemini",
    "workflow",
    "research",
    "sessions",
    "caches",
    "model-context-protocol"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "knip": "knip",
    "check:static": "npm run build && npm run type-check && eslint . && prettier --check . && knip",
    "check": "npm run check:static && npm run test",
    "test": "node --import tsx/esm --env-file=.env --test --no-warnings",
    "inspector": "npm run build && npx -y @modelcontextprotocol/inspector node --env-file=.env dist/index.js",
    "tasks": "node scripts/tasks.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@google/genai": "^1.51",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "express": "^5.2.1",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.9.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
