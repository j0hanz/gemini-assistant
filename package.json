{
  "name": "gemini-assistant",
  "version": "1.0.0",
  "description": "General-purpose Gemini AI assistant exposed as an MCP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check": "tsc && eslint . && prettier --check . && knip",
    "inspector": "npm run build && npx -y @modelcontextprotocol/inspector node --env-file=.env dist/index.js"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/server": "alpha",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.1"
  }
}
