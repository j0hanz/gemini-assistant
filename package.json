{
  "name": "gemini-assistant",
  "version": "1.0.0",
  "description": "Workflow-first Gemini MCP server for chat, research, file analysis, review, and project memory",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j0hanz/gemini-assistant.git"
  },
  "keywords": [
    "mcp",
    "gemini",
    "workflow",
    "research",
    "sessions",
    "caches",
    "model-context-protocol"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "knip": "knip",
    "check": "tsc && eslint . && prettier --check . && knip",
    "test": "node --import tsx/esm --env-file=.env --test --no-warnings __tests__/**/*.test.ts __tests__/**/**/*.test.ts",
    "inspector": "npm run build && npx -y @modelcontextprotocol/inspector node --env-file=.env dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/express": "2.0.0-alpha.2",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "express": "^5.2.1",
    "ignore": "^7.0.5",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
